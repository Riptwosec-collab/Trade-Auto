# ============================================================
# APEX TRADE — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control
# ============================================================

# ── APP ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_SECRET=your_super_secret_jwt_key_min_32_chars_here
FRONTEND_URL=http://localhost:3000

# ── DATABASE (Supabase / PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/apextrade?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/apextrade

# ── REDIS (Upstash or Railway Redis) ─────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── BINANCE API ──────────────────────────────────────────────
# Get keys at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true          # set false for live trading
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret

# ── ALPACA API (Stocks / US Equities) ────────────────────────
# Get keys at: https://app.alpaca.markets/paper
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading
# ALPACA_BASE_URL=https://api.alpaca.markets       # live trading
ALPACA_DATA_URL=https://data.alpaca.markets

# ── IBKR (Interactive Brokers) ───────────────────────────────
# Requires TWS or IB Gateway running locally
IBKR_HOST=127.0.0.1
IBKR_PORT=7497              # 7497 = paper, 4001 = live gateway
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=your_ibkr_account_id

# ── MARKET DATA (optional extras) ────────────────────────────
POLYGON_API_KEY=your_polygon_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── NOTIFICATIONS ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── RISK LIMITS ──────────────────────────────────────────────
MAX_RISK_PER_TRADE=1          # % of capital
DAILY_LOSS_LIMIT=2            # % of capital
WEEKLY_LOSS_LIMIT=5           # % of capital
MAX_CONSECUTIVE_LOSSES=3
MAX_DRAWDOWN_PCT=10

# ── RAILWAY / VERCEL DEPLOYMENT ──────────────────────────────
# These are set automatically by Railway — do not edit
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=apex-trade-backend
