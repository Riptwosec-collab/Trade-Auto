{
  "name": "apex-trade-backend",
  "version": "1.0.0",
  "description": "APEX TRADE — Professional Trading Platform Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev":     "ts-node-dev --respawn --transpile-only src/app.ts",
    "build":   "tsc",
    "start":   "node dist/app.js",
    "lint":    "eslint src --ext .ts",
    "typecheck":"tsc --noEmit"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.2.1",
    "@stoqey/ib":                 "^1.0.20",
    "binance-api-node":           "^0.12.5",
    "cors":                       "^2.8.5",
    "express":                    "^4.18.2",
    "helmet":                     "^7.1.0",
    "morgan":                     "^1.10.0",
    "redis":                      "^4.6.13",
    "socket.io":                  "^4.7.4",
    "zod":                        "^3.22.4"
  },
  "devDependencies": {
    "@types/cors":                "^2.8.17",
    "@types/express":             "^4.17.21",
    "@types/morgan":              "^1.9.9",
    "@types/node":                "^20.11.5",
    "ts-node-dev":                "^2.0.0",
    "typescript":                 "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
